# Telegram Bot (required for the assistant to communicate)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=["YOUR_TELEGRAM_USER_ID","SPOUSE_TELEGRAM_USER_ID"]

# Primary user Telegram chat ID (used by ask-via-telegram extension)
PRIMARY_TELEGRAM_CHAT_ID=YOUR_TELEGRAM_USER_ID

# Google OAuth2 — enables Gmail, Calendar, and Tasks integration
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Google Maps API — enables drive time, directions, and route planning
# Get a key at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Feature Flags
CRON_ENABLED=true

# Optional — enables voice note transcription via OpenAI Whisper
OPENAI_API_KEY=your_openai_api_key_here

# Optional — enables social media scheduling via Late/Zernio
ZERNIO_API_KEY=your_zernio_api_key_here
LATE_API_KEY=your_late_api_key_here

# Optional — enables Gemini AI video analysis
GEMINI_API_KEY=your_gemini_api_key_here
